# Database
DATABASE_URL="postgresql://autooffice:dev@localhost:5433/autooffice"

# Redis
REDIS_URL="redis://localhost:6379"

# Server
PORT=3001
NODE_ENV=development

# Google OAuth ログイン（Google Cloud Console > 認証情報 > OAuth 2.0クライアントID）
# リダイレクトURI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=change-this-in-production

# Google Calendar (どちらか一方を設定。未設定時はモックデータ使用)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=   # サービスアカウントJSONファイルのパス
GOOGLE_SERVICE_ACCOUNT_KEY=        # JSONを直接文字列で指定する場合

# Slack（Bot Token。未設定時はtimes非表示）
# 必要スコープ: channels:read, channels:history
# ボットをtimes-*チャンネルに招待してください
SLACK_BOT_TOKEN=

# Frontend
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
